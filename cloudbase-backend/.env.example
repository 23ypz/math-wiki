PORT=80
DATABASE_URL=mysql://USER:PASSWORD@HOST:4000/kaoyan_math
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=your-login-email@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ALLOWED_ORIGIN=https://23ypz.github.io
INIT_TOKEN=replace-with-an-init-token
TIDB_SSL=true

# CloudBase 云存储（图片上传）
# 在 CloudBase 控制台环境概览查看环境 ID；云托管内通常也可自动识别。
CLOUDBASE_ENV_ID=your-cloudbase-env-id
# 可选：云存储默认 CDN 域名，例如 https://xxxx.tcb.qcloud.la
# 配置后生成长期稳定的图片 URL；不配置时后端会返回长期临时链接。
CLOUDBASE_STORAGE_DOMAIN=https://your-storage-domain.tcb.qcloud.la
