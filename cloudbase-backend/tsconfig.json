{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "sourceMap": true
  },
  "include": ["server.ts", "vercel-compat.d.ts", "api/**/*.ts", "src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
