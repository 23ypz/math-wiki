DATABASE_URL=mysql://USER:PASSWORD@HOST:4000/DATABASE_NAME
JWT_SECRET=change-me-to-a-long-random-secret
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me
ALLOWED_ORIGIN=http://localhost:5173
INIT_TOKEN=change-me-init-token
TIDB_SSL=true

# CloudBase 云存储（仅在此后端也接入 CloudBase 时使用）
CLOUDBASE_ENV_ID=your-cloudbase-env-id
CLOUDBASE_STORAGE_DOMAIN=https://your-storage-domain.tcb.qcloud.la
